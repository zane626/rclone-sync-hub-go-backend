{
    "swagger": "2.0",
    "info": {
        "description": "文件上传调度系统 REST API：任务列表、扫描、重试、统计等",
        "title": "Rclone Sync Hub API",
        "termsOfService": "http://swagger.io/terms/",
        "contact": {
            "name": "API Support",
            "url": "https://github.com/your-org/rclone-sync-hub"
        },
        "license": {
            "name": "Apache 2.0",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/api/analytics/dashboard": {
            "get": {
                "description": "返回概览数字、按状态/按监听文件夹/按时间趋势的图表数据，以及最近任务与失败任务列表，供数据分析页一次拉取",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "analytics"
                ],
                "summary": "数据分析仪表盘",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "趋势图天数，默认 7",
                        "name": "days",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/service.DashboardData"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/fs/subdirs": {
            "get": {
                "description": "根据传入的本地路径，返回该路径下所有一级子文件夹（不包含文件）",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "filesystem"
                ],
                "summary": "获取指定路径下的子文件夹",
                "parameters": [
                    {
                        "type": "string",
                        "description": "本地起始路径，如 /volumes",
                        "name": "path",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.FSSubDirListResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/rclone/configs": {
            "get": {
                "description": "调用 `rclone config show` 并解析出 remote 名称与类型，过滤掉敏感字段",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "rclone"
                ],
                "summary": "获取 rclone remote 配置列表",
                "responses": {
                    "200": {
                        "description": "items 为 remote 列表",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "error 为错误信息",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/tasks": {
            "get": {
                "description": "按状态筛选并分页返回上传任务，不传 status 时返回全部",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "tasks"
                ],
                "summary": "分页获取上传任务列表",
                "parameters": [
                    {
                        "type": "string",
                        "description": "任务状态: pending|running|success|failed，空为全部",
                        "name": "status",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "default": 1,
                        "description": "页码，从 1 开始",
                        "name": "page",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "default": 20,
                        "description": "每页条数",
                        "name": "page_size",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "items 为任务列表，total 为总条数",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "error 为错误信息",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "post": {
                "description": "新建一个上传任务（默认状态为待上传）",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "tasks"
                ],
                "summary": "创建上传任务",
                "parameters": [
                    {
                        "description": "任务配置",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.TaskCreateReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.UploadTask"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/tasks/batch/delete": {
            "post": {
                "description": "对传入的任务 ID 列表执行删除操作，running 状态的任务会失败并给出原因",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "tasks"
                ],
                "summary": "批量删除上传任务",
                "parameters": [
                    {
                        "description": "任务 ID 列表",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.TaskBatchReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/service.TaskBatchResult"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/tasks/batch/pause": {
            "post": {
                "description": "对传入的任务 ID 列表执行暂停操作，running 状态的任务会失败并给出原因",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "tasks"
                ],
                "summary": "批量暂停上传任务",
                "parameters": [
                    {
                        "description": "任务 ID 列表",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.TaskBatchReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/service.TaskBatchResult"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/tasks/batch/retry": {
            "post": {
                "description": "对传入的任务 ID 列表执行重试操作，running 状态的任务会失败并给出原因",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "tasks"
                ],
                "summary": "批量重试上传任务",
                "parameters": [
                    {
                        "description": "任务 ID 列表",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.TaskBatchReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/service.TaskBatchResult"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/tasks/{id}": {
            "delete": {
                "description": "上传中的任务不可删除",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "tasks"
                ],
                "summary": "删除上传任务",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "任务 ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "boolean"
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/tasks/{id}/logs": {
            "get": {
                "description": "按任务 ID 返回 upload_logs 中的日志列表，支持 limit 限制条数",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "tasks"
                ],
                "summary": "获取任务上传日志",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "任务 ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "最多返回条数，默认 500",
                        "name": "limit",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/model.UploadLog"
                            }
                        }
                    },
                    "400": {
                        "description": "invalid id",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/tasks/{id}/pause": {
            "post": {
                "description": "上传中的任务不可暂停",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "tasks"
                ],
                "summary": "暂停上传任务",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "任务 ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "boolean"
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/watch-folders": {
            "get": {
                "description": "按状态分页获取监听文件夹列表",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "watch-folders"
                ],
                "summary": "列出监听文件夹",
                "parameters": [
                    {
                        "type": "string",
                        "description": "状态: detecting|watching|stopped|paused|error",
                        "name": "status",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "default": 1,
                        "description": "页码，从 1 开始",
                        "name": "page",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "default": 20,
                        "description": "每页条数",
                        "name": "page_size",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "items 为列表，total 为总数",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "post": {
                "description": "新增一个被监听并同步到指定 rclone remote 的本地目录",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "watch-folders"
                ],
                "summary": "创建监听文件夹",
                "parameters": [
                    {
                        "description": "监听文件夹配置",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.WatchFolderCreateReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.WatchFolder"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/watch-folders/{id}": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "watch-folders"
                ],
                "summary": "获取监听文件夹详情",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "监听文件夹 ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.WatchFolder"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "put": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "watch-folders"
                ],
                "summary": "更新监听文件夹",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "监听文件夹 ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "更新内容（全部可选）",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.WatchFolderUpdateReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.WatchFolder"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "delete": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "watch-folders"
                ],
                "summary": "删除监听文件夹",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "监听文件夹 ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "boolean"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "api.FSSubDir": {
            "type": "object",
            "properties": {
                "has_sub_dirs": {
                    "type": "boolean"
                },
                "name": {
                    "type": "string"
                },
                "path": {
                    "type": "string"
                }
            }
        },
        "api.FSSubDirListResponse": {
            "type": "object",
            "properties": {
                "items": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/api.FSSubDir"
                    }
                }
            }
        },
        "api.TaskBatchReq": {
            "type": "object",
            "required": [
                "ids"
            ],
            "properties": {
                "ids": {
                    "description": "任务 ID 列表",
                    "type": "array",
                    "items": {
                        "type": "integer"
                    }
                }
            }
        },
        "api.TaskCreateReq": {
            "type": "object",
            "required": [
                "local_path",
                "remote_name",
                "remote_path"
            ],
            "properties": {
                "file_name": {
                    "type": "string"
                },
                "file_size": {
                    "type": "integer"
                },
                "local_path": {
                    "type": "string"
                },
                "remote_name": {
                    "type": "string"
                },
                "remote_path": {
                    "type": "string"
                },
                "watch_folder_id": {
                    "type": "integer"
                },
                "watch_folder_name": {
                    "type": "string"
                }
            }
        },
        "api.WatchFolderCreateReq": {
            "type": "object",
            "required": [
                "local_path",
                "name",
                "remote_name",
                "remote_path"
            ],
            "properties": {
                "local_path": {
                    "type": "string"
                },
                "max_depth": {
                    "description": "可选，0 表示不限制",
                    "type": "integer"
                },
                "name": {
                    "type": "string"
                },
                "remote_name": {
                    "type": "string"
                },
                "remote_path": {
                    "type": "string"
                },
                "scan_interval_seconds": {
                    "description": "可选，默认 300",
                    "type": "integer"
                },
                "sync_type": {
                    "description": "可选，默认 local_to_remote",
                    "type": "string"
                }
            }
        },
        "api.WatchFolderUpdateReq": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "local_path": {
                    "type": "string"
                },
                "max_depth": {
                    "type": "integer"
                },
                "name": {
                    "type": "string"
                },
                "remote_name": {
                    "type": "string"
                },
                "remote_path": {
                    "type": "string"
                },
                "scan_interval_seconds": {
                    "type": "integer"
                },
                "status": {
                    "type": "string"
                },
                "sync_type": {
                    "type": "string"
                }
            }
        },
        "model.FileRecord": {
            "type": "object",
            "properties": {
                "createdAt": {
                    "type": "string"
                },
                "fileHash": {
                    "description": "可选，用于去重",
                    "type": "string"
                },
                "fileSize": {
                    "type": "integer"
                },
                "id": {
                    "type": "integer"
                },
                "localPath": {
                    "type": "string"
                },
                "relativePath": {
                    "description": "相对扫描根目录的路径",
                    "type": "string"
                },
                "remotePath": {
                    "type": "string"
                },
                "updatedAt": {
                    "type": "string"
                },
                "uploadedAt": {
                    "type": "string"
                }
            }
        },
        "model.UploadLog": {
            "type": "object",
            "properties": {
                "bytesDone": {
                    "type": "integer"
                },
                "bytesTotal": {
                    "type": "integer"
                },
                "createdAt": {
                    "type": "string"
                },
                "id": {
                    "type": "integer"
                },
                "message": {
                    "type": "string"
                },
                "percent": {
                    "type": "number"
                },
                "speed": {
                    "description": "bytes/s",
                    "type": "integer"
                },
                "taskID": {
                    "type": "integer"
                }
            }
        },
        "model.UploadTask": {
            "type": "object",
            "properties": {
                "accumulatedFailures": {
                    "description": "累计失败次数（便于分析）",
                    "type": "integer"
                },
                "createdAt": {
                    "type": "string"
                },
                "durationSeconds": {
                    "description": "时间维度",
                    "type": "integer"
                },
                "errorMsg": {
                    "description": "最后一次错误信息",
                    "type": "string"
                },
                "fileName": {
                    "description": "文件名",
                    "type": "string"
                },
                "fileRecord": {
                    "description": "关联（不参与表结构，仅查询用）",
                    "allOf": [
                        {
                            "$ref": "#/definitions/model.FileRecord"
                        }
                    ]
                },
                "fileRecordID": {
                    "type": "integer"
